# --- App ---
APP_NAME=THAI_PHC_V2
POSTGRES_DATABASE_URL=postgres://user:pass@localhost:5432/thaqi
API_V1_PREFIX=/api/v1

# --- OAuth2 / OIDC ---
# Issuer must match the Discovery issuer and the iss claim in tokens
OIDC_ISSUER=http://localhost:8000/api/v1/auth

# Audience of access tokens (resource server identifier)
ACCESS_TOKEN_AUDIENCE=hss-api

# Token settings
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=60
JWT_SESSION_TOKEN_EXPIRE_MINUTES=10

# First-login token (HS256) secret
JWT_FIRST_LOGIN_TOKEN_SECRET_KEY=change_me_first_login_secret
JWT_FIRST_LOGIN_TOKEN_EXPIRE_MINUTES=5
JWT_FIRST_LOGIN_TOKEN_ALGORITHM=HS256

# RSA key files used for RS256 signing
JWT_PRIVATE_KEY_PATH=private_key.pem
JWT_PUBLIC_KEY_PATH=public_key.pem

# Optional: Multiple key rotation support
# JSON map of kid->path for private/public keys; set JWT_ACTIVE_KID to the one used to sign new tokens
# Example: {"key-1":"private_key.pem","key-2":"private_next.pem"}
#JWT_PRIVATE_KEYS={}
#JWT_PUBLIC_KEYS={}
JWT_ACTIVE_KID=key-1

# Allow small clock skew (seconds) for token verification
JWT_CLOCK_SKEW_SECONDS=30

# Cookie hardening flags (prod)
COOKIE_SECURE=true
COOKIE_SAMESITE=Lax

# Optional symmetric key fallback (not used for RS256)
JWT_SECRET_KEY=change_me_strong_secret

# Super admin user IDs (comma-separated UUIDs) that can create OAuth clients
SUPER_ADMIN_USER_IDS=d40c4c01-dd8f-434f-99a7-d539cb09282b
